<!-- omikuji_app/app/views/fortunes/show.html.erb -->
<% fortune ||= @fortune %>

<div class="max-w-md mx-auto bg-white border-2 border-stone-100 shadow-[0_20px_50px_rgba(0,0,0,0.1)] p-8 font-serif relative overflow-hidden animate-slide-up">
  <!-- Red Border Frame -->
  <div class="absolute inset-2 border border-red-100 pointer-events-none"></div>

  <!-- Decorative Header -->
  <div class="text-center border-b-4 border-double border-red-800 pb-6 mb-8">
    <h2 class="text-4xl text-red-800 font-bold tracking-[0.5em] ml-[0.5em]">御神籤</h2>
    <div class="flex justify-between items-center mt-4 px-2">
      <span class="text-[10px] text-stone-400 font-bold tracking-widest uppercase">Tokyo Region</span>
      <span class="text-[10px] text-stone-400 font-bold tracking-widest uppercase">ID: #<%= format('%04d', fortune.id) %></span>
    </div>
  </div>

  <!-- Rank (The Big Blessing) -->
  <div class="text-center mb-12 py-8 bg-stone-50/50 relative">
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none">
      <span class="text-9xl font-black italic">OMIKUJI</span>
    </div>
    <span class="text-7xl font-black text-red-700 tracking-tighter drop-shadow-sm">
      <%= fortune.rank.split(' ').first %>
    </span>
    <p class="text-xs text-red-900/40 mt-4 font-bold tracking-[0.2em] uppercase">
      <%= fortune.rank.split(' ').last %>
    </p>
  </div>

  <!-- Sentiment Analysis Detail (The Technical Flex) -->
  <div class="mb-10 px-6 border-l-2 border-stone-200">
    <h3 class="text-[10px] font-black text-stone-300 uppercase tracking-widest mb-3">Your Echo</h3>
    <p class="text-xl text-stone-800 leading-relaxed italic">"<%= fortune.input_text %>"</p>
    <div class="mt-4 flex items-center space-x-3">
      <div class="h-1 flex-grow bg-stone-100 rounded-full overflow-hidden">
        <div class="h-full <%= fortune.sentiment_label == 'positive' ? 'bg-green-600' : 'bg-amber-600' %>" 
             style="width: <%= [(fortune.score.abs * 100).to_i, 100].min %>%"></div>
      </div>
      <span class="text-[9px] font-bold text-stone-400 uppercase tracking-tighter whitespace-nowrap">
        BERT Confidence: <%= (fortune.score.abs * 100).round(1) %>%
      </span>
    </div>
  </div>

  <!-- The Fortune Text (GPT-2 Output) -->
  <div class="mb-12 text-center px-4 relative">
    <div class="text-red-800/10 text-6xl absolute -top-4 -left-2 font-serif">"</div>
    <p class="text-2xl leading-relaxed text-stone-900 font-medium">
      <%= fortune.fortune_text.gsub(/[「」]/, '') %>
    </p>
    <div class="text-red-800/10 text-6xl absolute -bottom-10 -right-2 font-serif">"</div>
  </div>

  <!-- Action -->
  <div class="text-center border-t border-stone-100 pt-8">
    <%= link_to root_path, class: "group inline-flex flex-col items-center no-underline" do %>
      <span class="text-red-800 font-black text-sm tracking-widest uppercase group-hover:text-red-600 transition-colors">Return to Shrine</span>
      <span class="text-[10px] text-stone-300 mt-1 italic">Draw another destiny</span>
    <% end %>
  </div>

  <!-- Background Watermark -->
  <div class="absolute -bottom-12 -right-12 opacity-[0.03] transform rotate-12 pointer-events-none">
    <span class="text-[15rem] font-black italic">福</span>
  </div>
</div>
