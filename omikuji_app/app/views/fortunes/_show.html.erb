<!-- omikuji_app/app/views/fortunes/_show.html.erb -->
<% fortune ||= @fortune %>

<div class="max-w-md mx-auto my-12 bg-white shadow-[0_40px_100px_-20px_rgba(0,0,0,0.15)] rounded-2xl p-10 font-serif relative overflow-hidden animate-slide-up border border-stone-100">
  <!-- Subtle Header -->
  <div class="flex justify-between items-start mb-12 border-b border-stone-100 pb-8">
    <div class="text-left">
      <h2 class="text-2xl font-black text-red-800 tracking-[0.3em]">御神籤</h2>
      <p class="text-[9px] text-stone-400 font-bold uppercase tracking-[0.2em] mt-1">Divine Echo #<%= format('%04d', fortune.id) %></p>
    </div>
    <div class="text-right">
       <span class="text-[9px] font-black text-stone-300 uppercase tracking-widest">Local Inference</span>
       <div class="h-0.5 w-8 bg-red-800 ml-auto mt-1"></div>
    </div>
  </div>

  <!-- Rank (The Big Blessing) -->
  <div class="text-center mb-16 relative py-12 bg-stone-50/50 rounded-xl border border-white">
    <span class="text-8xl font-black text-red-700 tracking-tighter drop-shadow-xl block">
      <%= fortune.rank.split(' ').first %>
    </span>
    <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-white px-4 py-1 rounded-full border border-stone-100 shadow-sm">
      <p class="text-[10px] text-stone-500 font-black tracking-[0.3em] uppercase whitespace-nowrap">
        <%= fortune.rank.split(' ').last %>
      </p>
    </div>
  </div>

  <!-- Sentiment Analysis Detail -->
  <div class="mb-16">
    <div class="flex items-center space-x-3 mb-4">
      <div class="w-2 h-2 rounded-full <%= fortune.sentiment_label == 'positive' ? 'bg-green-500' : 'bg-amber-500' %>"></div>
      <h3 class="text-[10px] font-black text-stone-400 uppercase tracking-widest"><%= fortune.sentiment_label %> Sentiment Detected</h3>
    </div>
    <p class="text-2xl text-stone-800 leading-tight italic font-medium mb-6">"<%= fortune.input_text %>"</p>
    <div class="flex items-center space-x-3">
      <div class="h-1 flex-grow bg-stone-100 rounded-full overflow-hidden">
        <div class="h-full <%= fortune.sentiment_label == 'positive' ? 'bg-green-600' : 'bg-amber-600' %> transition-all duration-1000" 
             style="width: <%= [(fortune.score.abs * 100).to_i, 100].min %>%"></div>
      </div>
      <span class="text-[10px] font-black text-stone-500 tracking-tighter">
        <%= (fortune.score.abs * 100).round(1) %>%
      </span>
    </div>
  </div>

  <!-- The Fortune Text (GPT-2 Output) -->
  <div class="mb-16 text-center px-6 relative">
    <div class="w-12 h-[1px] bg-stone-200 mx-auto mb-8"></div>
    <p class="text-3xl leading-[1.4] text-stone-900 font-medium tracking-tight">
      <%= fortune.fortune_text.gsub(/[「」]/, '') %>
    </p>
    <div class="w-12 h-[1px] bg-stone-200 mx-auto mt-8"></div>
  </div>

  <!-- Action Footer -->
  <div class="grid grid-cols-2 gap-4 pt-10 border-t border-stone-100">
    <div data-controller="share" data-share-url-value="<%= fortune_url(fortune) %>">
      <button data-action="click->share#copy" class="w-full flex flex-col items-center group cursor-pointer">
        <div class="p-3 rounded-full bg-stone-50 group-hover:bg-red-50 transition-colors mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-stone-400 group-hover:text-red-700 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </div>
        <span data-share-target="label" class="text-[9px] font-black uppercase tracking-widest text-stone-500 group-hover:text-red-800 transition-colors">Copy Divine Link</span>
      </button>
    </div>

    <%= link_to root_path, class: "w-full flex flex-col items-center group no-underline" do %>
      <div class="p-3 rounded-full bg-stone-50 group-hover:bg-red-50 transition-colors mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-stone-400 group-hover:text-red-700 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      </div>
      <span class="text-[9px] font-black uppercase tracking-widest text-stone-500 group-hover:text-red-800 transition-colors">Return to Shrine</span>
    <% end %>
  </div>

  <!-- Subtle Watermark -->
  <div class="absolute -top-10 -right-10 opacity-[0.03] pointer-events-none transform rotate-12">
    <span class="text-[12rem] font-black">福</span>
  </div>
</div>
