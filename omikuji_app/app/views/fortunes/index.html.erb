<!-- omikuji_app/app/views/fortunes/index.html.erb -->

<div class="max-w-2xl mx-auto py-12 px-4">
  <header class="text-center mb-12">
    <h1 class="text-5xl font-serif text-gray-800 mb-2">感情おみくじ</h1>
    <p class="text-xl text-gray-600 italic">Sentiment Omikuji</p>
    <div class="w-24 h-1 bg-red-700 mx-auto mt-4"></div>
  </header>

  <main class="bg-stone-50 border-double border-4 border-stone-200 p-8 shadow-sm">
    <div class="text-center mb-8">
      <p class="text-lg text-gray-700 mb-6">
        How are you feeling right now? <br>
        <span class="text-sm text-gray-500">(Enter a thought in Japanese to receive your fortune)</span>
      </p>

      <%= form_with model: @fortune, class: "space-y-6" do |f| %>
        <div>
          <%= f.text_area :input_text, 
              rows: 3, 
              class: "w-full p-4 border-stone-300 focus:ring-red-700 focus:border-red-700 text-lg font-serif",
              placeholder: "今日はとても..." %>
        </div>
        
        <div>
          <%= f.submit "Draw a Fortune (おみくじを引く)", 
              class: "bg-red-800 text-white px-8 py-3 text-lg font-bold hover:bg-red-900 transition-colors cursor-pointer shadow-md" %>
        </div>
      <% end %>
    </div>

    <div id="fortune_result">
      <!-- Turbo will inject the result here -->
    </div>
  </main>

  <footer class="mt-16">
    <h2 class="text-sm font-bold uppercase tracking-widest text-gray-400 text-center mb-6">Recent Blessings</h2>
    <div id="recent_fortunes" class="grid grid-cols-1 gap-4">
      <% @fortunes.each do |f| %>
        <div class="bg-white p-4 border border-stone-100 flex justify-between items-center text-sm">
          <span class="text-gray-600 truncate max-w-xs">"<%= f.input_text %>"</span>
          <span class="font-bold <%= f.sentiment_label == 'positive' ? 'text-green-700' : 'text-amber-700' %>">
            <%= f.rank %>
          </span>
        </div>
      <% end %>
    </div>
  </footer>
</div>
